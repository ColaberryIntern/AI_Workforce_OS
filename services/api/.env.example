# --- Server ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# --- Database (Postgres) ---
DATABASE_URL=postgres://aiwos:aiwos@localhost:5432/aiwos

# --- Auth (Build Guide §8) ---
JWT_SECRET=change-me-in-prod-use-32-byte-random-secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN_DAYS=14

# --- Encryption at rest (Build Guide §8) ---
# 32-byte hex key for AES-256-GCM. Generate via:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Webhooks ---
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_ATTEMPTS=4

# --- CORS ---
CORS_ORIGIN=http://localhost:5173
